{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "patient-touch",
  "compatibility_date": "2026-02-02",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "patient-touch-db",
      "database_id": "b3918de1-1d51-426d-ab33-0062e18a0de2"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "patient-touch-audio"
    }
  ],
  "vars": {
    "OPENAI_API_KEY": "",
    "GOOGLE_CLIENT_ID": "324228075950-01gun79ntvi30vop51ahlb0uljpu5rv0.apps.googleusercontent.com"
  }
}
