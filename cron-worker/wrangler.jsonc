{
  "name": "patient-touch-briefing-cron",
  "main": "index.js",
  "compatibility_date": "2024-01-01",
  // ① 브리핑: KST 06:00~22:00 매시 정각 = UTC 21:00~13:00
  //    유저별 notification_time의 '시'와 일치할 때만 Pages 쪽에서 실제 발송
  // ② 보존기간 파기: KST 04:00 = UTC 19:00 (하루 1회, index.js에서 event.cron으로 분기)
  "triggers": {
    "crons": ["0 21-23 * * *", "0 0-13 * * *", "0 19 * * *"]
  }
}
